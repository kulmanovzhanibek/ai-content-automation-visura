# Vertex AI (image generation). Paste the WHOLE service-account JSON on one line.
GCP_SERVICE_ACCOUNT=
# Optional: override project id (defaults to project_id from GCP_SERVICE_ACCOUNT)
# GCP_PROJECT_ID=
# Optional: Vertex region for the image model (default: global)
# GCP_LOCATION=global
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# --- Instagram publishing (Graph API content publishing) ---
# NOTE: the Graph API host graph.facebook.com must be allowed by the environment's
# network/egress policy, or publishing fails with a proxy 403 (see docs).
# Instagram Business/Creator account id (the "IG user id", NOT the @username).
IG_USER_ID=
# Long-lived access token with the instagram_content_publish permission.
# Read from IG_ACCESS_TOKEN, or VISURA_IG_API as an alias (either works).
IG_ACCESS_TOKEN=
# VISURA_IG_API=
# Optional: Graph API version / host (defaults: v23.0, graph.facebook.com).
# GRAPH_API_VERSION=v23.0
# GRAPH_API_HOST=graph.facebook.com
# GCS bucket used to host rendered mp4/png so Instagram can fetch them (IG can't
# take a local upload). Reuses GCP_SERVICE_ACCOUNT above. By default the upload
# returns a time-limited V4 SIGNED URL (bucket stays PRIVATE — works with uniform
# access / org public-access-prevention). One-time: grant that service account
# the "Storage Object Admin" role on the bucket. Name the bucket WITHOUT dots
# (a dotted name triggers GCS domain verification).
GCS_BUCKET=
# Optional: signed-URL lifetime in seconds (default 3600).
# GCS_SIGNED_URL_EXPIRES=3600
# Optional: set to "true" ONLY if the bucket is public-read (allUsers:
# objectViewer) — then the plain public URL is used instead of a signed one.
# GCS_PUBLIC=false
# Optional: only for the slides pipeline (brief -> slideshow concept via Claude).
# Without it slides-concept falls back to offline template concepts.
ANTHROPIC_API_KEY=

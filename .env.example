# Vertex AI (image generation). Paste the WHOLE service-account JSON on one line.
GCP_SERVICE_ACCOUNT=
# Optional: override project id (defaults to project_id from GCP_SERVICE_ACCOUNT)
# GCP_PROJECT_ID=
# Optional: Vertex region for the image model (default: global)
# GCP_LOCATION=global
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# --- Instagram publishing (Graph API content publishing) ---
# Instagram Business/Creator account id (the "IG user id", NOT the @username).
IG_USER_ID=
# Long-lived access token with the instagram_content_publish permission.
IG_ACCESS_TOKEN=
# Optional: Graph API version / host (defaults: v23.0, graph.facebook.com).
# GRAPH_API_VERSION=v23.0
# GRAPH_API_HOST=graph.facebook.com
# GCS bucket used to host rendered mp4/png at a PUBLIC url so Instagram can
# fetch them (IG can't take a local upload). Reuses GCP_SERVICE_ACCOUNT above.
# One-time: grant that service account "Storage Object Admin" on the bucket and
# grant allUsers "Storage Object Viewer" (public read) so IG can download.
GCS_BUCKET=
# Optional: only for the slides pipeline (brief -> slideshow concept via Claude).
# Without it slides-concept falls back to offline template concepts.
ANTHROPIC_API_KEY=
